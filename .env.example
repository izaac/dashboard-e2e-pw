# Dashboard E2E Test Configuration
# Copy to .env and fill in values.
#
# Quick start with Docker:
#   docker compose up                              # Starts Rancher + runs all tests
#   GREP_TAGS="@generic" docker compose up tests   # Run only @generic tests
#   docker compose down                            # Stop everything

# ─── Required ───────────────────────────────────────────────────────────────
TEST_BASE_URL=https://localhost:8005/dashboard
TEST_PASSWORD=

# ─── Optional ───────────────────────────────────────────────────────────────
TEST_USERNAME=admin
# CATTLE_BOOTSTRAP_PASSWORD=        # For first-time Rancher setup (auto-set by docker-compose)
# TEST_SKIP=setup                   # Comma-separated dirs to skip
# TEST_ONLY=                        # Comma-separated dirs to run exclusively

# ─── Tag Filtering (Cypress-compatible syntax) ──────────────────────────────
# GREP_TAGS=                        # Examples:
#   @adminUser                      # All admin tests
#   @generic                        # Lightweight local-friendly tests
#   @adminUser+-@prime+-@noVai      # Admin tests, excluding prime and noVai
#   @adminUser+-@needsInfra         # Admin tests, excluding cloud/infra-dependent

# ─── NixOS Only (set automatically by devenv shell) ────────────────────────
# PLAYWRIGHT_CHROMIUM_PATH=/etc/profiles/per-user/$USER/bin/chromium

# ─── Cloud Credentials (tests tagged @needsInfra, not needed locally) ──────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AZURE_AKS_SUBSCRIPTION_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# GKE_SERVICE_ACCOUNT=
# CUSTOM_NODE_IP=
# CUSTOM_NODE_KEY=

# ─── Docker Compose Overrides ──────────────────────────────────────────────
# RANCHER_IMAGE=docker.io/rancher/rancher:head    # Rancher image for docker-compose
# RANCHER_PASSWORD=admin                           # Bootstrap + test password

# ─── Host User Mapping (Docker test runner) ────────────────────────────────
# The tests container runs as ${HOST_UID}:${HOST_GID} so artifacts written via
# the bind-mount (test-results/, playwright-report/, .auth/) are owned by the
# host user instead of root. Defaults are 1000:100. Override if your host user
# differs — set explicitly or run with: HOST_UID=$(id -u) HOST_GID=$(id -g) ...
# HOST_UID=1000
# HOST_GID=100
