# Dashboard E2E Test Configuration
# Copy to .env and fill in values.

# --- Required ---
TEST_BASE_URL=https://localhost:8005/dashboard
TEST_PASSWORD=

# --- Optional ---
TEST_USERNAME=admin
# CATTLE_BOOTSTRAP_PASSWORD=        # For first-time Rancher setup
# TEST_SKIP=setup                   # Comma-separated dirs to skip
# TEST_ONLY=                        # Comma-separated dirs to run exclusively
# GREP_TAGS=                        # Filter by tag (@adminUser, @explorer, etc.)

# --- NixOS: Chromium path (set automatically by nix shell) ---
# PLAYWRIGHT_CHROMIUM_PATH=/etc/profiles/per-user/$USER/bin/chromium

# --- Cloud credentials (for provisioning tests) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AZURE_AKS_SUBSCRIPTION_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# GKE_SERVICE_ACCOUNT=
# CUSTOM_NODE_IP=
# CUSTOM_NODE_KEY=
