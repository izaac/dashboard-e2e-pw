{
  "name": "@rancher/playwright-e2e",
  "version": "1.0.0",
  "description": "Playwright E2E tests, utilities, page objects, and blueprints for Rancher Dashboard",
  "keywords": [
    "playwright",
    "e2e",
    "testing",
    "page-objects",
    "rancher"
  ],
  "author": "Rancher",
  "license": "Apache-2.0",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:jenkins": "playwright test --config=playwright.config.jenkins.ts",
    "test:grep": "playwright test --grep",
    "test:list": "playwright test --list",
    "report": "playwright show-report",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write '**/*.ts'",
    "format:check": "prettier --check '**/*.ts'",
    "typecheck": "tsc --noEmit",
    "summarize-failures": "npx tsx scripts/summarize-failures.ts",
    "po-index": "npx tsx scripts/generate-po-index.ts",
    "po-diff": "npx tsx scripts/generate-po-index.ts --diff",
    "gap-map": "npx tsx scripts/generate-gap-map.ts",
    "branch-diff": "sh scripts/branch-backport.sh",
    "api-diff": "npx tsx scripts/api-diff.ts",
    "local:up": "docker compose up rancher -d",
    "local:test": "docker compose up tests",
    "local:test:sharded": "docker compose -f docker-compose.sharded.yml up",
    "local:down": "docker compose down",
    "local:down:sharded": "docker compose -f docker-compose.sharded.yml down -v",
    "local:report": "npx playwright show-report",
    "prepare": "husky",
    "lint:md": "markdownlint-cli2"
  },
  "dependencies": {
    "@axe-core/playwright": "4.10.1",
    "@playwright/test": "1.52.0",
    "dotenv": "16.4.7",
    "dotenv-expand": "11.0.7",
    "playwright-qase-reporter": "2.0.12",
    "typescript": "5.8.3",
    "ws": "8.18.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "24.12.2",
    "@types/ws": "8.5.14",
    "@typescript-eslint/eslint-plugin": "8.32.0",
    "@typescript-eslint/parser": "8.32.0",
    "eslint": "9.26.0",
    "eslint-plugin-playwright": "2.2.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "3.5.3",
    "tsx": "4.21.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.md": [
      "markdownlint-cli2 --fix"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rancher/dashboard.git",
    "directory": "playwright"
  },
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=22"
  }
}
